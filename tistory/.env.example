# 복사해서 .env 로 저장한 뒤 값을 채우세요. (.env 는 절대 커밋 금지)
TISTORY_ID=your_kakao_id
TISTORY_PW=your_kakao_password
TISTORY_BLOG_NAME=yourblog          # yourblog.tistory.com 의 yourblog 부분

# 자동화 동작 옵션
HEADLESS=false                      # true 면 브라우저 창 없이 실행
PUBLISH_VISIBILITY=0                # 0=비공개, 1=보호, 2=공개발행
POST_DELAY_SECONDS=7200             # 글 사이 최소 대기(초). 기본 2시간
MAX_POSTS_PER_RUN=3                 # 1회 실행 시 최대 발행 개수
